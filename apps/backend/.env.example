# ==============================================================================
# EMBEDDED COLLECTIVE BACKEND ENVIRONMENT TEMPLATE
# Copy this file to '.env' and populate with actual credentials.
# ==============================================================================

# Core Application Settings
PROJECT_NAME="Embedded Collective API"
ENVIRONMENT=development
API_V1_STR=/api/v1

# Port configuration (used by Docker and Render)
PORT=8000

# ------------------------------------------------------------------------------
# DATABASE & CACHE
# ------------------------------------------------------------------------------
# DATABASE_URL: Regional connection pooler port 6543 (transaction pooling)
# Format: postgresql://[user]:[password]@[host]:[port]/[database]
# It will be auto-rewritten to use postgresql+asyncpg:// internally.
DATABASE_URL=postgresql://postgres.ntmmdbuimcaqaoegfbwk:your-password@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true

# Upstash Redis connection string (SSL/TLS supported)
REDIS_URL=rediss://default:your-token@summary-owl-132944.upstash.io:6379

# ------------------------------------------------------------------------------
# CRYPTOGRAPHY & AUTHENTICATION
# ------------------------------------------------------------------------------
# SECRETY_KEY: Generate with `openssl rand -hex 32`
SECRET_KEY=e8f96e4719bb4abda09f90659cb128fe242be6a66a1a7f05ee45b91cfbbd6b5e
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
REFRESH_TOKEN_EXPIRE_DAYS=7

# Google OAuth Credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ------------------------------------------------------------------------------
# SERVICES: SMTP / OTP EMAIL
# ------------------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=m.harit04@gmail.com
SMTP_PASSWORD=your-gmail-app-password
SMTP_FROM="Embedded Collective <m.harit04@gmail.com>"

# ------------------------------------------------------------------------------
# SERVICES: SUPABASE BUCKET STORAGE
# ------------------------------------------------------------------------------
SUPABASE_URL=https://ntmmdbuimcaqaoegfbwk.supabase.co/rest/v1/
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_BUCKET=embedded-collective-uploads

# ------------------------------------------------------------------------------
# CORS & ADMINISTRATOR CONTACT
# ------------------------------------------------------------------------------
ADMIN_EMAIL=herry.pvt.hm@gmail.com
SUPERADMIN_EMAIL=haritmandaliya@gmail.com
ALLOWED_ORIGINS="http://localhost:5173,https://haritmandaliya.vercel.app,https://haritmandaliya-portfolio.vercel.app"
