# ──── PRODUCTION BACKEND ENVIRONMENT VARIABLES ────

# General FastAPI Configuration
PROJECT_NAME="Embedded Collective API"
ENVIRONMENT=production
API_V1_STR=/api/v1

# Supabase PostgreSQL (replace with production async credentials)
# Format: postgresql+asyncpg://<user>:<password>@<db-host>:<port>/<db-name>
DATABASE_URL=postgresql+asyncpg://postgres:[YOUR_SUPABASE_PASSWORD]@db.supabase.co:5432/postgres

# Upstash Redis
# Format: rediss://:<password>@<upstash-redis-endpoint>:<port>
REDIS_URL=rediss://default:[YOUR_UPSTASH_PASSWORD]@upstash-redis-endpoint:6379

# Cryptography / Security (Generate strong random keys in production)
# You can generate a key using: openssl rand -hex 32
SECRET_KEY=production_jwt_secret_key_change_me
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Google OAuth
GOOGLE_CLIENT_ID=473198912524-5vere2qbqcutil4hn9mlkvf52dnqal83.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=[YOUR_GOOGLE_CLIENT_SECRET]

# Email OTP (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=m.harit04@gmail.com
SMTP_PASSWORD=[YOUR_GMAIL_16_CHAR_APP_PASSWORD]
SMTP_FROM=m.harit04@gmail.com

# Twilio SMS OTP (Optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Cloudflare R2 / S3 Object Storage
R2_BUCKET_NAME=embedded-collective-assets
R2_ACCOUNT_ID=[YOUR_CLOUDFLARE_ACCOUNT_ID]
R2_ACCESS_KEY_ID=[YOUR_R2_ACCESS_KEY_ID]
R2_SECRET_ACCESS_KEY=[YOUR_R2_SECRET_ACCESS_KEY]
R2_CUSTOM_DOMAIN=assets.embeddedcollective.com

# Admin Notifications
ADMIN_EMAIL=haritmandaliya@gmail.com
